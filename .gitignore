/.cache
/.work
/_output
cover.out
/vendor
/.vendor-new
.DS_Store

# ignore IDE folders
.vscode/
.idea/

# ignore local environment / secret files (never commit gridscale creds)
.envrc
*.env
.env.local

# --- Committed spec-driven harness (ADR-0001 / D-000) ---
# The workspace global gitignore (~/.config/git/ignore) hides AGENTS.md and
# agent-context/ by default. For this public provider we deliberately COMMIT the
# harness as a maturity signal — re-include it here. Only .claude/ stays local.
!AGENTS.md
!agent-context/
!agent-context/**
# .claude/ (local coordination + worktrees) remains ignored by the global rule.
